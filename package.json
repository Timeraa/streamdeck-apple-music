{
  "name": "streamdeck-apple-music",
  "version": "1.0.0",
  "private": true,
  "description": "Stream Deck + dial control for Apple Music output volume on macOS",
  "license": "MIT",
  "author": "Timeraa",
  "type": "module",
  "scripts": {
    "build": "vp pack",
    "watch": "vp pack --watch --on-success \"streamdeck restart com.timeraa.apple-music-volume\"",
    "build:native": "cd native && ./build.sh",
    "link": "streamdeck link com.timeraa.apple-music-volume.sdPlugin",
    "restart": "streamdeck restart com.timeraa.apple-music-volume",
    "lint": "vp lint src",
    "format": "vp fmt src",
    "check": "vp fmt src && vp lint src && tsc --noEmit"
  },
  "dependencies": {
    "@elgato/streamdeck": "^1.0.0"
  },
  "devDependencies": {
    "@tsconfig/node20": "^20.1.4",
    "@types/node": "^20.19.42",
    "typescript": "^5.6.3",
    "vite-plus": "^0.1.24"
  },
  "packageManager": "npm@11.16.0"
}
